---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Vanguard Transformation Partners | Organization Facilitators", 
  description = "Vanguard Transformation Partners help facilitate for meaningful and lasting change in the workplace." 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  </head>
  <body class="global-body">
    
    <!-- Ambient Fluid Glass Glow Background -->
    <div class="ambient-bg">
      <div class="blob blob-1 animate-fluid-1"></div>
      <div class="blob blob-2 animate-fluid-2"></div>
      <div class="blob blob-3 animate-fluid-3"></div>
      <div class="grid-pattern"></div>
    </div>

    <!-- Main Content -->
    <slot />

    <style is:global>
      /* Design System & Variables */
      :root {
        --color-bg: #0b0c10;
        --color-text: #f5f6f9;
        --color-primary: #0ea5e9; /* Cyan 500 */
        --color-accent: #6366f1;  /* Indigo 500 */
        --color-glass-bg: rgba(13, 16, 23, 0.45);
        --color-glass-border: rgba(255, 255, 255, 0.08);
        --font-sans: 'Outfit', sans-serif;
        --font-serif: 'Playfair Display', serif;
      }

      /* Global CSS Resets & Base Styles */
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      .global-body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-sans);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #ffffff;
      }

      .font-editorial {
        font-family: var(--font-serif);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* Custom Premium Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #07080a;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        border: 2px solid #07080a;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-primary);
      }

      /* Ambient Background Styling */
      .ambient-bg {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: -50;
        overflow: hidden;
        background-color: #07080a;
      }

      .blob {
        position: absolute;
        border-radius: 9999px;
      }

      .blob-1 {
        top: -10%;
        left: -20%;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(circle, rgba(99, 102, 241, 1) 0%, rgba(99, 102, 241, 0) 70%);
        opacity: 0.3;
        filter: blur(120px);
      }

      .blob-2 {
        bottom: -10%;
        right: -10%;
        width: 50vw;
        height: 50vw;
        background: radial-gradient(circle, rgba(14, 165, 233, 1) 0%, rgba(14, 165, 233, 0) 70%);
        opacity: 0.2;
        filter: blur(130px);
      }

      .blob-3 {
        top: 30%;
        right: 20%;
        width: 40vw;
        height: 40vw;
        background: radial-gradient(circle, rgba(6, 182, 212, 1) 0%, rgba(6, 182, 212, 0) 70%);
        opacity: 0.15;
        filter: blur(100px);
      }

      .grid-pattern {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-size: 40px 40px;
        background-image: 
          linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        opacity: 0.5;
      }

      /* Fluid Glass container styling */
      .fluid-glass-card {
        background: var(--color-glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--color-glass-border);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        border-radius: 16px;
        transition: border-color 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
      }

      .fluid-glass-card:hover {
        border-color: rgba(14, 165, 233, 0.3);
        box-shadow: 0 12px 40px 0 rgba(14, 165, 233, 0.1);
      }

      /* Animations for the fluid background blobs */
      @keyframes float-1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(10vw, 5vh) scale(1.1); }
        66% { transform: translate(-5vw, 10vh) scale(0.95); }
      }
      @keyframes float-2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-8vw, -10vh) scale(1.15); }
      }
      @keyframes float-3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        40% { transform: translate(6vw, -8vh) scale(0.9); }
      }

      .animate-fluid-1 {
        animation: float-1 25s infinite ease-in-out;
      }
      .animate-fluid-2 {
        animation: float-2 20s infinite ease-in-out;
      }
      .animate-fluid-3 {
        animation: float-3 28s infinite ease-in-out;
      }

      /* Premium hover and button animations */
      .glass-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 9999px;
        color: #ffffff;
        font-weight: 500;
        padding: 0.75rem 1.75rem;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
      }

      .glass-btn:hover {
        background: #ffffff;
        color: #07080a;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(255, 255, 255, 0.15);
      }

      .glass-btn-primary {
        background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #ffffff;
      }

      .glass-btn-primary:hover {
        background: linear-gradient(135deg, #38bdf8, #818cf8);
        color: #ffffff;
        box-shadow: 0 10px 25px rgba(14, 165, 233, 0.4);
      }
    </style>
  </body>
</html>

---
// Header.astro
import logoImage from '../../Vanguard-JUNE2020-Logo-S5_HORIZONTAL---W.png';
---
<header class="header">
  <div class="background"></div>
  <a href="/" class="logo">
    <img src={logoImage.src} alt="Vanguard Logo" class="logo-img" />
  </a>
  <nav class="nav">
    <a href="/" class="link">Home</a>
    <a href="/transformations" class="link">Transformations</a>
    <a href="/#team" class="link">Our Team</a>
    <a href="/#contact" class="link">Contact</a>
  </nav>

  <!-- Mobile Menu Button -->
  <button class="hamburger" aria-label="Toggle Menu">
    <span class="hamburger-box">
      <span class="hamburger-inner"></span>
    </span>
  </button>

  <!-- Mobile Overlay -->
  <div class="mobile-menu">
    <div class="mobile-glow-orb"></div>
    <div class="mobile-menu-container">
      <nav class="mobile-nav">
        <div class="mobile-link-wrapper" style="--stagger: 1"><a href="/" class="mobile-link">Home</a></div>
        <div class="mobile-link-wrapper" style="--stagger: 2"><a href="/transformations" class="mobile-link">Transformations</a></div>
        <div class="mobile-link-wrapper" style="--stagger: 3"><a href="/#team" class="mobile-link">Our Team</a></div>
        <div class="mobile-link-wrapper" style="--stagger: 4"><a href="/#contact" class="mobile-link">Contact</a></div>
      </nav>
      
      <div class="mobile-footer" style="--stagger: 5">
        <p class="mobile-footer-text">Start your journey today.</p>
        <a href="mailto:hello@vanguard.com" class="mobile-email">hello@vanguard.com</a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 8rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-md);
    z-index: 50;
    color: var(--color-white);
  }

  .background {
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: -1;
    transition: all 0.3s ease-in-out;
  }

  .logo-img {
    height: 5rem;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    gap: 4rem;
  }

  .link {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    position: relative;
    padding: 1rem 0;
    white-space: nowrap;
  }

  .link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 0.5s cubic-bezier(1, 0, 0, 1);
  }

  .link:hover::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  .hamburger {
    display: none;
    cursor: pointer;
    z-index: 100;
    padding: 1rem;
    background: transparent;
    border: none;
  }

  .hamburger-box {
    width: 30px;
    height: 20px;
    display: inline-block;
    position: relative;
  }

  .hamburger-inner {
    display: block;
    top: 50%;
    margin-top: -1px;
    transition-duration: 0.22s;
    transition-timing-function: cubic-bezier(0.55, 0.055, 0.675, 0.19);
  }

  .hamburger-inner, .hamburger-inner::before, .hamburger-inner::after {
    width: 30px;
    height: 2px;
    background-color: var(--color-white);
    position: absolute;
    transition-property: transform;
    border-radius: 2px;
  }

  .hamburger-inner::before, .hamburger-inner::after {
    content: "";
    display: block;
  }

  .hamburger-inner::before {
    top: -8px;
    transition: top 0.1s 0.25s ease-in, opacity 0.1s ease-in;
  }

  .hamburger-inner::after {
    bottom: -8px;
    transition: bottom 0.1s 0.25s ease-in, transform 0.22s cubic-bezier(0.55, 0.055, 0.675, 0.19);
  }

  .hamburger.is-active .hamburger-inner {
    transform: rotate(225deg);
    transition-delay: 0.12s;
    transition-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);
  }

  .hamburger.is-active .hamburger-inner::before {
    top: 0;
    opacity: 0;
    transition: top 0.1s ease-out, opacity 0.1s 0.12s ease-out;
  }

  .hamburger.is-active .hamburger-inner::after {
    bottom: 0;
    transform: rotate(-90deg);
    transition: bottom 0.1s ease-out, transform 0.22s 0.12s cubic-bezier(0.215, 0.61, 0.355, 1);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(11, 16, 18, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.77, 0, 0.175, 1);
    overflow: hidden;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-glow-orb {
    position: absolute;
    top: 30%;
    left: 50%;
    width: 80vw;
    height: 80vw;
    background: radial-gradient(circle, rgba(137,207,240,0.15) 0%, rgba(0,0,0,0) 70%);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .mobile-menu.is-open .mobile-glow-orb {
    opacity: 1;
    transition-delay: 0.3s;
  }

  .mobile-menu-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rem;
    width: 100%;
    padding: 0 2rem;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    text-align: center;
    width: 100%;
  }

  .mobile-link-wrapper {
    overflow: hidden;
    padding: 0.5rem 0;
  }

  .mobile-link {
    display: inline-block;
    font-size: clamp(3rem, 10vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-white);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1), color 0.3s ease;
  }

  .mobile-menu.is-open .mobile-link {
    transform: translateY(0);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
    transition-delay: calc(0.1s + (var(--stagger) * 0.08s));
  }

  .mobile-link:hover {
    color: var(--color-taupe);
  }

  .mobile-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    transform: translateY(2rem);
    opacity: 0;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .mobile-menu.is-open .mobile-footer {
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
    transition-delay: calc(0.2s + (var(--stagger) * 0.08s));
  }

  .mobile-footer-text {
    font-size: 1.1rem;
    color: var(--color-taupe);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .mobile-email {
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--color-white);
    position: relative;
    display: inline-block;
    padding-bottom: 0.5rem;
  }

  .mobile-email::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 0.5s cubic-bezier(1, 0, 0, 1);
  }

  .mobile-email:hover::after {
    transform: scaleX(1);
    transform-origin: left center;
  }



  @media (max-width: 1024px) {
    .nav {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const headerBg = document.querySelector('.header .background');
    
    const checkScroll = () => {
      if (window.scrollY > 50) {
        if (headerBg) {
          headerBg.style.backgroundColor = 'rgba(11, 16, 18, 0.9)';
          headerBg.style.backdropFilter = 'blur(2rem)';
          headerBg.style.webkitBackdropFilter = 'blur(2rem)';
        }
      } else {
        if (headerBg) {
          headerBg.style.backgroundColor = 'transparent';
          headerBg.style.backdropFilter = 'none';
          headerBg.style.webkitBackdropFilter = 'none';
        }
      }
    };

    window.addEventListener('scroll', checkScroll);
    checkScroll(); // Check on load

    // Mobile Menu Logic
    const hamburger = document.querySelector('.hamburger');
    const mobileMenu = document.querySelector('.mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (hamburger && mobileMenu) {
      const toggleMenu = () => {
        const isOpen = mobileMenu.classList.toggle('is-open');
        hamburger.classList.toggle('is-active');
        document.body.style.overflow = isOpen ? 'hidden' : '';
      };

      hamburger.addEventListener('click', toggleMenu);
      mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));
    }
  });
</script>

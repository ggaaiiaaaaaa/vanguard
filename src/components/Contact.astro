---
// Contact.astro
import Button from './Button.astro';
---
<section class="contact-panel" id="contact">
  <div class="container">
    <div class="grid-24">
      <div class="contact-content">
        <h2 class="contact-title">
          Ready to ignite lasting transformation?
        </h2>
        <Button href="mailto:connect@vanguardleadership.com.ph" text="Get In Touch" variant="is-white" size="large" />
      </div>
    </div>
  </div>
</section>

<style>
  .contact-panel {
    background-color: var(--color-black);
    color: var(--color-white);
    padding: var(--space-xl) 0;
    border-bottom: 1px solid rgba(255,255,255,0.2);
  }

  .contact-content {
    grid-column: 2 / 24;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .contact-content {
      grid-column: 6 / 20;
    }
  }

  .contact-title {
    font-size: 4rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .contact-title {
      font-size: 8rem;
    }
  }


</style>

---
// ServicesCollection.astro
---
<section class="services-collection" id="about">
  <div class="container">
    <div class="header">
      <h2 class="title">We Are</h2>
      <p class="description">Our Core Values.</p>
    </div>
    
    <div class="grid-24 blocks">
      <div class="block block-1">
        <div class="image-wrapper">
          <img class="image-placeholder" src="https://images.unsplash.com/photo-1454496522488-7a8e488e8606?auto=format&fit=crop&w=800&q=80" alt="Mountain Peak - Faithful" />
          <div class="image-overlay"></div>
        </div>
        <div class="block-content">
          <h3 class="block-title">Faithful</h3>
          <p class="block-desc">We pursue lasting results by stewarding our time, talent, and resources.</p>
        </div>
      </div>
      
      <div class="block block-2">
        <div class="image-wrapper">
          <img class="image-placeholder" src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=800&q=80" alt="Ocean Waves - Courageous" />
          <div class="image-overlay"></div>
        </div>
        <div class="block-content">
          <h3 class="block-title">Courageous</h3>
          <p class="block-desc">We are forerunners, taking every situation with courage and humility.</p>
        </div>
      </div>
      
      <div class="block block-3">
        <div class="image-wrapper">
          <img class="image-placeholder" src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=800&q=80" alt="Helping Hands - Servant Spirited" />
          <div class="image-overlay"></div>
        </div>
        <div class="block-content">
          <h3 class="block-title">Servant-Spirited</h3>
          <p class="block-desc">We serve and empower those we lead, connect and partner with.</p>
        </div>
      </div>

      <div class="block block-4">
        <div class="image-wrapper">
          <img class="image-placeholder" src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80" alt="Modern Architecture - Excellent" />
          <div class="image-overlay"></div>
        </div>
        <div class="block-content">
          <h3 class="block-title">Excellent</h3>
          <p class="block-desc">We are committed to building a culture of integrity, genuine respect, and trust.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services-collection {
    background-color: var(--color-black);
    color: var(--color-white);
    padding: var(--space-xl) 0;
  }

  .header {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 3rem;
    margin-bottom: 8rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .title {
    font-size: 3.2rem;
    font-weight: 400;
  }

  .description {
    font-family: var(--font-mono);
    color: var(--color-taupe);
    font-size: 1.4rem;
  }

  .blocks {
    padding-top: 4rem;
    row-gap: 8rem;
  }

  .block {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    text-align: center;
    padding: 2rem;
  }

  .image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.2s var(--ease-out-cubic);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%);
    opacity: 0.6;
    transition: opacity 0.8s var(--ease-out-cubic);
    z-index: 1;
  }

  .block:hover .image-placeholder {
    transform: scale(1.08);
  }

  .block:hover .image-overlay {
    opacity: 0.9;
  }

  .block-content {
    position: relative;
    z-index: 2;
  }

  .block-title {
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }
  
  .block-desc {
    font-size: 1.4rem;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s var(--ease-out-cubic);
  }

  .block:hover .block-desc {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .block-1 {
      grid-column: 2 / 10;
      margin-top: 10rem;
    }
    .block-2 {
      grid-column: 12 / 24;
    }
    .block-3 {
      grid-column: 1 / 11;
      margin-top: -15rem;
    }
    .block-4 {
      grid-column: 14 / 22;
      margin-top: -5rem;
    }
    .block-title {
      font-size: 3.2rem;
    }
    .block-desc {
      font-size: 1.6rem;
    }
  }
</style>



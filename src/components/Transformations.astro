---
// Transformations.astro
import Button from './Button.astro';
---
<section class="transformations-panel" id="transformations">
  <div class="container">
    <div class="header">
      <h2 class="title">Transformations</h2>
      <p class="description">Meaningful and lasting change.</p>
    </div>
    
    <div class="cases">
      <div class="case-item">
        <div class="case-image">
          <img src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&fit=crop&w=1600&q=80" alt="Coffee Bean & Tea Leaf" class="placeholder" />
        </div>
        <div class="case-content">
          <span class="case-category">The Coffee Bean & Tea Leaf</span>
          <h3 class="case-title">Identity Fortified</h3>
          <Button href="#" text="Read Case Study" />
        </div>
      </div>

      <div class="case-item reverse">
        <div class="case-image">
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1600&q=80" alt="Habitat for Humanity" class="placeholder" />
        </div>
        <div class="case-content">
          <span class="case-category">Excellence in Adversity</span>
          <h3 class="case-title">Habitat for Humanity Philippines </h3>
          <Button href="#" text="Read Case Study" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .transformations-panel {
    background-color: var(--color-white);
    color: var(--color-black);
    padding: var(--space-xl) 0;
  }

  .header {
    border-top: 1px solid rgba(0, 0, 0, 0.2);
    padding-top: 3rem;
    margin-bottom: 8rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  @media (max-width: 767px) {
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  .title {
    font-size: 3.2rem;
    font-weight: 400;
  }

  .description {
    font-family: var(--font-mono);
    color: var(--color-grey);
    font-size: 1.4rem;
  }

  .cases {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .case-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .case-item {
      grid-template-columns: repeat(24, 1fr);
      gap: 2rem;
    }
  }

  .case-image {
    width: 100%;
    overflow: hidden;
  }

  .placeholder {
    width: 100%;
    height: 60vh;
    object-fit: cover;
    display: block;
    transition: transform 1.5s var(--ease-out-cubic);
  }

  @media (min-width: 768px) {
    .case-item .case-image {
      grid-column: 2 / 16;
    }
    
    .case-item.reverse .case-image {
      grid-column: 10 / 24;
    }
  }

  .case-item:hover .placeholder {
    transform: scale(1.05);
  }

  .case-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .case-item .case-content {
      grid-column: 18 / 24;
    }
    
    .case-item.reverse .case-content {
      grid-column: 2 / 8;
      grid-row: 1;
    }
  }

  .case-category {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-grey);
    border-bottom: 1px solid var(--color-grey);
    padding-bottom: 1rem;
    display: inline-block;
  }

  .case-title {
    font-size: 4rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
</style>

